# Server-only Qwen credentials. Never expose QWEN_API_KEY through a PUBLIC_ variable.
QWEN_API_KEY=

# OpenAI-compatible API base. The default below is used when this value is empty.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Any Qwen model available to your compatible endpoint.
QWEN_MODEL=qwen-plus
