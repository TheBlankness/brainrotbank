# Server-only Qwen credentials. Never expose QWEN_API_KEY through a PUBLIC_ variable.
QWEN_API_KEY=

# OpenAI-compatible API base. For this OpenWebUI instance, use /api — not the admin URL.
QWEN_BASE_URL=https://openwebui.sisedu.org/api

# Model ID exactly as it appears in OpenWebUI.
QWEN_MODEL=qwen3.5:122b
